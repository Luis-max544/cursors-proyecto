# Database
DATABASE_URL=postgresql://user:password@localhost:5433/nutrilearn

# Redis
REDIS_URL=redis://localhost:6379

# JWT — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_32_chars_minimum_access_secret
JWT_REFRESH_SECRET=change_me_32_chars_minimum_refresh_secret

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# AWS S3 / Cloudflare R2
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET=nutrilearn-videos

# CDN base URL (used to generate presigned HLS URLs)
CDN_URL=https://cdn.nutrilearn.io

# CORS
CORS_ORIGIN=http://localhost:5173

# API
PORT=4000
NODE_ENV=development
